rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (request.auth.token.email == "danielgiobari644@gmail.com" ||
         exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin');
    }

    match /settings/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /content/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /services/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /sermons/{sermonId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /events/{eventId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /quotes/{quoteId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /moments/{momentId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /testimonies/{testimonyId} {
      allow read: if true;
      allow create: if true;
      allow update, delete: if isAdmin();
    }

    match /messages/{messageId} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }

    match /admin/{docId} {
      allow read: if true;
      allow write: if true; // Temporarily allow for initialization, should be hardened later
    }

    match /users/{userId} {
      allow read: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      allow write: if isAdmin();
    }
    
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
