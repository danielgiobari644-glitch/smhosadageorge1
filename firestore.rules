rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isSignedIn() { return request.auth != null; }
    function isAdmin() { 
      return isSignedIn() && 
             request.auth.token.email == "danielgiobari644@gmail.com" && 
             request.auth.token.email_verified == true; 
    }

    // Broadest possible read access for the whole database
    match /{document=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Specific collections with public permissions
    match /testimonies/{testimonyId} {
      allow read: if true;
      allow create: if true;
      allow update, delete: if isAdmin();
    }
    
    match /messages/{messageId} {
      allow read: if isAdmin(); // Only admin should read messages
      allow create: if true;
      allow update, delete: if isAdmin();
    }

    match /events/{eventId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}

